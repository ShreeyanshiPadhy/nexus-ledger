{
  "tabs": [
    {
      "id": "Tab_1_Basics",
      "label": "Process Unit Basics",
      "fields": [
        { 
          "id": "unit_name", 
          "label": "Process Unit Identifier", 
          "type": "text", 
          "placeholder": "e.g., Hydrocracker-A", 
          "required": true, 
          "gridSpan": "half",
          "regex": "^[a-zA-Z0-9- ]{3,}$", 
          "errors": { "empty": "Unit Identifier is required.", "invalid": "At least 3 alphanumeric characters." } 
        },
        {
          "id": "fluid_phase",
          "label": "Secondary Fluid Phase Layout",
          "type": "select",
          "required": true,
          "gridSpan": "half",
          "options": [
            { "label": "Select phase...", "value": "" },
            { "label": "Gas / Vapor Phase", "value": "gas" },
            { "label": "Liquid Phase Blend", "value": "liquid" }
          ],
          "destructiveTriggers": {
            "warnOnValueChange": true,
            "warningMessage": "Changing the Primary Fluid Phase will clear down all calculations and metrics entered on subsequent tabs. Do you wish to proceed?",
            "scope": "downstream"
          },
          "errors": { "empty": "Please select the fluid phase layout.", "invalid": "" }
        },
        { 
          "id": "stream_tag", 
          "label": "P&ID Tag Reference Code", 
          "type": "text", 
          "placeholder": "e.g., 10-HC-3001-2X", 
          "required": true, 
          "gridSpan": "half",
          "errors": { "empty": "P&ID blueprint cross-reference tag is required." } 
        },
        { 
          "id": "fluid_type", 
          "label": "Hydrocarbon Stream Classification", 
          "type": "select", 
          "gridSpan": "half",
          "options": [
            { "label": "Sour Crude Blend (High Sulfur)", "value": "sour" }, 
            { "label": "Sweet Distillate Fraction", "value": "sweet" }, 
            { "label": "Heavy Bitumen / Slurry Tanking", "value": "heavy" }, 
            { "label": "Produced Process Water", "value": "water" }
          ], 
          "required": true,
          "errors": { "empty": "Fluid classification category selection is mandatory." }
        },
        { 
          "id": "operating_mode", 
          "label": "Unit Operational Feed Profile", 
          "type": "radio", 
          "gridSpan": "full",
          "options": [
            { "label": "Continuous Fed Stream (Steady State Flow)", "value": "continuous" }, 
            { "label": "Batch Cyclic Loading (Time-Variant Blocks)", "value": "batch" }, 
            { "label": "Intermittent Standby (Surge Reservoir)", "value": "intermittent" }
          ], 
          "required": true,
          "errors": { "empty": "Operating profile mode must be specified." }
        }
      ]
    },
    {
      "id": "Tab_2_Metallurgy",
      "label": "Metallurgy & Vessel Integrity",
      "fields": [
        {
          "id": "moc",
          "label": "Material of Construction (MOC) Selection",
          "type": "select",
          "required": true,
          "gridSpan": "half",
          "optionsFromReduxKey": "metallurgySpecs",
          "errors": { "empty": "Metallurgy baseline specification is required." }
        },
        { 
          "id": "joint_efficiency", 
          "label": "Welding Joint Efficiency Coefficient (E)", 
          "type": "select", 
          "gridSpan": "half",
          "options": [
            { "label": "Fully Radiographed Seamless Connections (1.00)", "value": "1.0" }, 
            { "label": "Spot Non-Destructive Examined (0.85)", "value": "0.85" }, 
            { "label": "Unexamined Non-Critical Welds (0.70)", "value": "0.7" }
          ], 
          "required": true,
          "errors": { "empty": "Joint coefficient metric selection required." }
        },
        { 
          "id": "corrosion_allowance", 
          "label": "Design Corrosion Allowance Boundary", 
          "type": "text", 
          "placeholder": "e.g., 3.0", 
          "required": true, 
          "gridSpan": "half",
          "regex": "^\\d+(\\.\\d+)?$", 
          "errors": { "empty": "Corrosion allowance safety depth thickness must be mapped.", "invalid": "Must be positive numeric value." } 
        },
        { 
          "id": "nominal_wall", 
          "label": "Nominal Pipe Schedule Wall Thickness", 
          "type": "select", 
          "gridSpan": "half",
          "options": [
            { "label": "Select pipe wall thickness schedule...", "value": "" },
            { "label": "Schedule 40 (Standard Operational Wall)", "value": "sch40" }, 
            { "label": "Schedule 80 (Extra Heavy Safety Wall)", "value": "sch80" }, 
            { "label": "Schedule 160 (High Pressure Pipeline Wall)", "value": "sch160" }
          ], 
          "required": true,
          "errors": { "empty": "Vessel/pipe mechanical profile wall rating required." }
        },
        { 
          "id": "pwht_required", 
          "label": "Post-Weld Heat Treatment (PWHT) Protocol", 
          "type": "checkbox", 
          "required": false,
          "gridSpan": "full"
        },
        { 
          "id": "h2s_service", 
          "label": "Sour Gas NACE Compliance (MR0175/ISO 15156)", 
          "type": "checkbox", 
          "required": false,
          "gridSpan": "full"
        }
      ]
    },
    {
      "id": "Tab_3_Thermodynamics",
      "label": "Thermodynamics safety Envelope",
      "calculations": [
        {
          "type": "THERMO_SAFETY_ENVELOPE",
          "outputs": [
            { "label": "Material Structural Yield Strengths:", "metricKey": "selectedMOCOutput", "variant": "bold" },
            { "label": "Calculated Max Pressure Allowance Bounds:", "metricKey": "maxSafePressureOutput", "variant": "bold" },
            { "label": "Overpressure Operational Excursion Risk:", "metricKey": "isPressureExceeded", "variant": "statusPill" }
          ]
        },
        {
          "type": "SCHEMA_MATH",
          "outputs": [
            {
              "label": "Thermal Safety Margin",
              "metricKey": "tempMargin",
              "variant": "bold",
              "formula": "[design_temp] - [op_temp]",
              "decimals": 1
            },
            {
              "label": "System Pressure Ratio (%)",
              "metricKey": "pressureRatio",
              "variant": "indigo",
              "formula": "([op_press] / [design_press]) * 100",
              "decimals": 2
            }
          ]
        }
      ],
      "fields": [
        { 
          "id": "op_temp", 
          "label": "Normal Operating Stream Temperature", 
          "type": "text", 
          "placeholder": "e.g., 280", 
          "required": true, 
          "gridSpan": "half",
          "regex": "^-?\\d+(\\.\\d+)?$", 
          "unitGroup": "temperature",
          "errors": { "empty": "Operating temperature tracking is mandatory to map thermal design.", "invalid": "Please input a valid numeric value." } 
        },
        { 
          "id": "design_temp", 
          "label": "Maximum Structural Design Temperature", 
          "type": "text", 
          "placeholder": "e.g., 350", 
          "required": true, 
          "gridSpan": "half",
          "regex": "^-?\\d+(\\.\\d+)?$", 
          "unitGroup": "temperature",
          "errors": { "empty": "Upper engineering thermal constraints must be designated.", "invalid": "Please input a valid numeric value." } 
        },
        { 
          "id": "op_press", 
          "label": "Normal Operating Process Pressure", 
          "type": "text", 
          "placeholder": "e.g., 35.0", 
          "required": true, 
          "gridSpan": "half",
          "regex": "^\\d+(\\.\\d+)?$", 
          "unitGroup": "pressure",
          "errors": { "empty": "Baseline operational stream load pressure tracking is required.", "invalid": "Value must be positive number." } 
        },
        { 
          "id": "design_press", 
          "label": "Maximum Allowed Vessel Design Pressure", 
          "type": "text", 
          "placeholder": "e.g., 45.5", 
          "required": true, 
          "gridSpan": "half",
          "regex": "^\\d+(\\.\\d+)?$", 
          "unitGroup": "pressure",
          "errors": { "empty": "Vessel high-pressure bursting barrier metric is required.", "invalid": "Value must be a positive number." } 
        },
        { 
          "id": "vapor_pressure", 
          "label": "True Vapor Pressure (TVP @ Peak Temp)", 
          "type": "text", 
          "placeholder": "e.g., 1.2", 
          "required": false, 
          "gridSpan": "half",
          "regex": "^\\d+(\\.\\d+)?$", 
          "unitGroup": "pressure",
          "errors": { "invalid": "Must be valid positive pressure." } 
        },
        { 
          "id": "critical_temp", 
          "label": "Fluid Thermodynamic Critical Temperature (Tc)", 
          "type": "text", 
          "placeholder": "e.g., 364.9", 
          "required": false, 
          "gridSpan": "half",
          "regex": "^-?\\d+(\\.\\d+)?$", 
          "unitGroup": "temperature",
          "errors": { "invalid": "Must be valid real temperature figure." } 
        }
      ]
    },
    {
      "id": "Tab_4_Kinetics",
      "label": "Reaction Kinetics Profile",
      "skipCondition": {
        "field": "fluid_phase",
        "value": "liquid"
      },
      "calculations": [
        {
          "type": "SCHEMA_MATH",
          "outputs": [
            {
              "label": "Effective Bed Residence Time (s)",
              "metricKey": "residenceTime",
              "variant": "indigo",
              "formula": "(3600 / [space_velocity]) * [bed_voidage]",
              "decimals": 2
            }
          ]
        }
      ],
      "fields": [
        { 
          "id": "space_velocity", 
          "label": "Gas Hourly Space Velocity Multiplier (GHSV)", 
          "type": "text", 
          "placeholder": "e.g., 1500", 
          "required": true, 
          "gridSpan": "half",
          "regex": "^\\d+(\\.\\d+)?$", 
          "errors": { "empty": "Space velocity metrics are compulsory for reactive catalyst modeling.", "invalid": "Must be a positive numeric value." } 
        },
        { 
          "id": "conversion_target", 
          "label": "Target Single-Pass Fractional Conversion", 
          "type": "text", 
          "placeholder": "e.g., 65.0", 
          "required": true, 
          "gridSpan": "half",
          "regex": "^\\d+(\\.\\d+)?$", 
          "errors": { "empty": "Chemical conversion yield parameters cannot be blank.", "invalid": "Enter numeric scale percentage value." } 
        },
        { 
          "id": "activation_energy", 
          "label": "Arrhenius Catalytic Activation Energy (Ea)", 
          "type": "text", 
          "placeholder": "e.g., 85.4", 
          "required": false, 
          "gridSpan": "half",
          "regex": "^\\d+(\\.\\d+)?$", 
          "errors": { "invalid": "Must be standard positive numeric index value." } 
        },
        { 
          "id": "bed_voidage", 
          "label": "Catalyst Fixed Packed Bed Void Fraction (ε)", 
          "type": "text", 
          "placeholder": "e.g., 0.40", 
          "required": true, 
          "gridSpan": "half",
          "regex": "^0\\.\\d+$", 
          "errors": { "empty": "Void coefficient porosity boundary required.", "invalid": "Must be decimal between 0.0 and 1.0." } 
        },
        { 
          "id": "catalyst_spec", 
          "label": "Active Catalyst Chemical Specification Compound & Mesh Description Log", 
          "type": "textarea", 
          "placeholder": "e.g., Gamma-Alumina Extrudates doped with 0.5wt% Precious Platinum / Palladium mesh clusters to execute sulfur-cracking procedures safely...", 
          "required": false, 
          "gridSpan": "full",
          "errors": { "empty": "", "invalid": "" } 
        }
      ]
    },
